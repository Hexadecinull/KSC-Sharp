<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KSCSharp.App.Views.FastFlagsWindow"
        Icon="avares://KSC-Sharp.App/Assets/icon.png"
        Title="FastFlags"
        Width="580" Height="500"
        MinWidth="440" MinHeight="380"
        CanResize="True"
        Background="{DynamicResource SurfaceBrush}">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="18">

    <TextBlock Grid.Row="0" Text="FastFlags" Classes="h1" Margin="0,0,0,14"/>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBox x:Name="TxtKey" Watermark="Key (e.g. FFlagDebugGraphicsDisableMetal)" Width="290"/>
      <TextBox x:Name="TxtValue" Watermark="Value (e.g. true)" Width="130"/>
      <Button x:Name="BtnAddOrUpdate" Content="Add / Update" Classes="secondary"/>
    </StackPanel>

    <Border Grid.Row="2" Classes="card" Padding="4">
      <ListBox x:Name="FlagsList" Background="Transparent" BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto" Margin="4,3">
              <TextBlock Grid.Column="0" Text="{Binding Display}" VerticalAlignment="Center"
                         FontFamily="Consolas,Menlo,monospace" FontSize="12.5"/>
              <Button Grid.Column="1" Content="Remove" Classes="ghost" Click="RemoveFlag_Click" Tag="{Binding}"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <TextBlock Grid.Row="3" x:Name="StatusText" Classes="subtle" Margin="2,10,0,0"/>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button x:Name="BtnCancel" Content="Cancel" Classes="ghost"/>
      <Button x:Name="BtnSave" Content="Save" Classes="secondary"/>
      <Button x:Name="BtnApplyNow" Content="Save &amp; Apply to Installed Clients" Classes="primary"/>
    </StackPanel>

  </Grid>
</Window>
