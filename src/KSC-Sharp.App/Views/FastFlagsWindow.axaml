<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KSCSharp.App.Views.FastFlagsWindow"
        Title="FastFlags"
        Width="560" Height="480"
        MinWidth="420" MinHeight="360"
        CanResize="True">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="12">

    <TextBlock Grid.Row="0" Text="FastFlags" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <TextBox x:Name="TxtKey" Watermark="Key (e.g. FFlagDebugGraphicsDisableMetal)" Width="280"/>
      <TextBox x:Name="TxtValue" Watermark="Value (e.g. true)" Width="140"/>
      <Button x:Name="BtnAddOrUpdate" Content="Add / Update"/>
    </StackPanel>

    <ListBox Grid.Row="2" x:Name="FlagsList">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="*,Auto" Margin="0,2">
            <TextBlock Grid.Column="0" Text="{Binding Display}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Remove" Click="RemoveFlag_Click" Tag="{Binding}"/>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBlock Grid.Row="3" x:Name="StatusText" Margin="0,8,0,0" Opacity="0.7" FontSize="12"/>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
      <Button x:Name="BtnApplyNow" Content="Save &amp; Apply to Installed Clients"/>
      <Button x:Name="BtnSave" Content="Save"/>
      <Button x:Name="BtnCancel" Content="Cancel"/>
    </StackPanel>

  </Grid>
</Window>
