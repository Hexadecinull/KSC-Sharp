<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KSCSharp.App.Views.MainWindow"
        Icon="avares://KSC-Sharp.App/Assets/icon.png"
        Title="KSC-Sharp"
        Width="960" Height="660"
        MinWidth="780" MinHeight="520"
        Background="{DynamicResource SurfaceBrush}">
  <Grid ColumnDefinitions="220,*">

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{DynamicResource InkBrush}">
      <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="14,20,14,16">

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,0,0,18">
          <Image Source="avares://KSC-Sharp.App/Assets/icon.png" Width="30" Height="30"/>
          <StackPanel>
            <TextBlock Text="KSC-Sharp" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="for Korone" FontSize="11" Foreground="#A79CD6"/>
          </StackPanel>
        </StackPanel>

        <Panel Grid.Row="1" Margin="0,0,0,10">
          <TextBox x:Name="SearchBox" Watermark="Search features…" Width="192"
                   Background="#332C58" BorderThickness="0" Foreground="White"/>
          <Border x:Name="SearchResultsPanel" IsVisible="False" Background="{DynamicResource InkSoftBrush}"
                  CornerRadius="8" Margin="0,36,0,0" Padding="4" ZIndex="10">
            <ListBox x:Name="SearchResultsList" Classes="searchresult" Background="Transparent" BorderThickness="0" MaxHeight="220"/>
          </Border>
        </Panel>

        <StackPanel Grid.Row="2" Spacing="2">
          <Button x:Name="NavLaunch" Classes="navitem selected" Content="▶  Launch"/>
          <Button x:Name="NavIntegrations" Classes="navitem" Content="⚙  Integrations"/>
          <Button x:Name="NavFastFlags" Classes="navitem" Content="⚑  FastFlags"/>
          <Button x:Name="NavGlobalSettings" Classes="navitem" Content="◧  Global Settings"/>
          <Button x:Name="NavLog" Classes="navitem" Content="≡  Log"/>
          <Button x:Name="NavAbout" Classes="navitem" Content="ℹ  About"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="SidebarVersionText" Foreground="#8079AA" FontSize="11" Margin="4,0,0,0"/>
      </Grid>
    </Border>

    <!-- Content -->
    <Grid Grid.Column="1" Margin="28,24,28,20">

      <!-- Launch page -->
      <StackPanel x:Name="LaunchPage" Spacing="16">
        <StackPanel>
          <TextBlock Text="Launch" Classes="h1"/>
          <TextBlock x:Name="SubtitleText" Classes="subtle"/>
        </StackPanel>

        <WrapPanel x:Name="VersionButtonsPanel"/>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Bootstrapper" Classes="h2"/>
              <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                         ToolTip.Tip="The bootstrapper is Pekora's own installer/updater program. Download it here, then run it whenever you want to install the client fresh or check for updates – KSC-Sharp itself doesn't install game files directly."/>
            </StackPanel>
            <WrapPanel>
              <Button x:Name="BtnFastFlags" Content="FastFlags…" Classes="secondary" Margin="0,0,8,8"/>
              <Button x:Name="BtnDownloadBootstrapper" Content="Download / Update" Classes="secondary" Margin="0,0,8,8"/>
              <Button x:Name="BtnLaunchBootstrapper" Content="Run Bootstrapper" Classes="secondary" Margin="0,0,8,8"/>
            </WrapPanel>
            <TextBlock x:Name="BootstrapperStatusText" Classes="subtle"/>
            <StackPanel x:Name="DownloadProgressRow" Orientation="Horizontal" Spacing="10" IsVisible="False">
              <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" Height="8" Width="260"
                           Foreground="{DynamicResource AccentBrush}"/>
              <TextBlock x:Name="ProgressText" Text="0%" Classes="subtle" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Integrations page -->
      <ScrollViewer x:Name="IntegrationsPage" IsVisible="False">
        <StackPanel Spacing="14" Margin="0,0,12,0">
          <StackPanel>
            <TextBlock Text="Integrations" Classes="h1"/>
            <TextBlock Text="Configure additional functionality to go alongside Korone." Classes="subtle"/>
          </StackPanel>

          <!-- Activity Tracking -->
          <TextBlock Text="Activity Tracking" Classes="h2" Margin="0,6,0,0"/>
          <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" Margin="2">
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Enable activity tracking" Classes="h2"/>
                <TextBlock Text="Allows for KSC-Sharp to detect what Korone game you're playing. Certain features may require this. This will make the integration with Discord RPC much better and smoother." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleActivityTracking" Grid.Row="0" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>

              <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Query server details" Classes="h2"/>
                  <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                             ToolTip.Tip="Reads the client's own log file for the server you joined, then looks up its rough location (city/region/country) via a public IP lookup – no Pekora involvement or proxy needed for that part. What's unverified is whether Pekora's log format matches the Roblox format this is based on."/>
                </StackPanel>
                <TextBlock Text="See roughly where your current game server is hosted, while a client is running." Classes="subtle" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                  <Button x:Name="BtnCheckServer" Content="Check Now" Classes="secondary"/>
                  <TextBlock x:Name="ServerDetailsText" Classes="subtle" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleQueryServerDetails" Grid.Row="2" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Top" HorizontalAlignment="Right"/>
            </Grid>
          </Border>

          <!-- Discord Rich Presence -->
          <TextBlock Text="Discord Rich Presence" Classes="h2" Margin="0,6,0,0"/>
          <TextBlock Text="This feature requires activity tracking to be enabled and the Discord desktop app to be installed and running."
                     Classes="subtle" TextWrapping="Wrap"/>
          <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" Margin="2">

              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Enable Discord Rich Presence" Classes="h2"/>
                <TextBlock Text="The master switch for this section. Requires the Discord desktop app to be installed and running." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleDiscordEnabled" Grid.Row="0" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>

              <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Show game activity" Classes="h2"/>
                <TextBlock Text="The client you're playing will be shown on your Discord profile." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleDiscordShowActivity" Grid.Row="2" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>

              <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Discord status display" Classes="h2"/>
                <TextBlock Text="Choose how much detail to show." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ComboBox x:Name="ComboDiscordDisplay" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="200">
                <ComboBoxItem Content="Name (Playing Korone)"/>
                <ComboBoxItem Content="Details (Playing Game)"/>
              </ComboBox>

              <Border Grid.Row="5" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="6" Grid.Column="0" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Allow activity joining" Classes="h2"/>
                  <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                             ToolTip.Tip="Adds a Join button to your Discord activity. Outbound only for now – friends can see and click it, but KSC-Sharp doesn't yet act on an incoming join request."/>
                </StackPanel>
                <TextBlock Text="Shows a Join button so friends can join your game from Discord." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleDiscordJoining" Grid.Row="6" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>

              <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="8" Grid.Column="0" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Show Pekora account" Classes="h2"/>
                  <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                             ToolTip.Tip="KSC-Sharp doesn't currently detect which Pekora account is logged in, so this has no visible effect yet – deliberately not faked. It's here so the setting is in the right place once account detection is added."/>
                </StackPanel>
                <TextBlock Text="Not yet functional – see the ⓘ for why." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleDiscordAccount" Grid.Row="8" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>

            </Grid>
          </Border>
          <TextBlock x:Name="DiscordStatusText" Classes="subtle"/>

          <!-- Window manipulation -->
          <TextBlock Text="Window Manipulation" Classes="h2" Margin="0,6,0,0"/>
          <Border Classes="card">
            <Grid RowDefinitions="Auto" ColumnDefinitions="*,Auto" Margin="2">
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Enable window manipulation" Classes="h2"/>
                  <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                             ToolTip.Tip="Windows only for now – Linux and macOS use entirely different windowing APIs that would need separate work."/>
                </StackPanel>
                <TextBlock Text="Allows KSC-Sharp to access Korone's window handle, allowing for better customization and features." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ToggleSwitch x:Name="ToggleWindowManipulation" Grid.Row="0" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
          </Border>

          <!-- Custom Integrations -->
          <TextBlock Text="Custom Integrations" Classes="h2" Margin="0,6,0,0"/>
          <TextBlock Text="Platform-specific ways to connect KSC-Sharp with your system's link handling and runtime."
                     Classes="subtle" TextWrapping="Wrap"/>

          <Border x:Name="WindowsIntegrationPanel" Classes="card">
            <StackPanel Spacing="10">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Windows" Classes="h2"/>
                <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="Registers pekora-player:// in the Windows registry (current user only, no admin needed) so clicking a join link in your browser opens KSC-Sharp instead of doing nothing."/>
              </StackPanel>
              <TextBlock Text="Registers the pekora-player:// link handler so join links from the browser open here."
                         Classes="subtle" TextWrapping="Wrap"/>
              <WrapPanel>
                <Button x:Name="BtnRegisterUri" Content="Register URI Scheme" Classes="secondary" Margin="0,0,8,0"/>
                <Button x:Name="BtnUnregisterUri" Content="Unregister URI Scheme" Classes="ghost" Margin="0,0,8,0"/>
              </WrapPanel>
              <TextBlock x:Name="UriSchemeStatusText" Classes="subtle"/>
            </StackPanel>
          </Border>

          <Border x:Name="LinuxIntegrationPanel" Classes="card">
            <StackPanel Spacing="10">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Linux" Classes="h2"/>
                <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="Adds a desktop entry and icon under your applications menu, and registers KSC-Sharp as the handler for pekora-player:// links. Safe to run again if you move the app – it just rewrites the entry."/>
              </StackPanel>
              <TextBlock Text="Experimental – client versions run under Wine. Adds a desktop entry, icon, and link handler."
                         Classes="subtle" TextWrapping="Wrap"/>
              <WrapPanel>
                <Button x:Name="BtnSetupLinuxIntegration" Content="Setup Desktop Integration" Classes="secondary" Margin="0,0,8,0"/>
                <Button x:Name="BtnRemoveLinuxIntegration" Content="Remove Desktop Integration" Classes="ghost" Margin="0,0,8,0"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Wine (Linux / macOS)" Classes="h2"/>
                <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="Pekora's client is a Windows program, so it needs Wine to run anywhere else. This shows whether KSC-Sharp could find a working Wine install."/>
              </StackPanel>
              <TextBlock x:Name="WineStatusText" Classes="subtle" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- FastFlags page -->
      <StackPanel x:Name="FastFlagsPage" Spacing="16" IsVisible="False">
        <StackPanel>
          <TextBlock Text="FastFlags" Classes="h1"/>
          <TextBlock Text="Control how specific Korone engine parameters and features are configured." Classes="subtle"/>
        </StackPanel>

        <Button x:Name="BtnOpenFastFlagEditor" Classes="settingsrow" Click="OpenFastFlagEditor_Click">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="🖊" FontSize="20" VerticalAlignment="Center" Margin="0,0,14,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="Fast Flag Editor" Classes="h2"/>
              <TextBlock Text="Manage your own Fast Flags. Use with caution." Classes="subtle"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Grid>
        </Button>

        <Border Classes="card">
          <Grid RowDefinitions="Auto" ColumnDefinitions="*,Auto" Margin="2">
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
              <TextBlock Text="Allow KSC-Sharp to manage Fast Flags" Classes="h2"/>
              <TextBlock Text="Disabling this prevents anything configured here from being applied to Korone." Classes="subtle" TextWrapping="Wrap"/>
            </StackPanel>
            <ToggleSwitch x:Name="ToggleFastFlagsManagement" Grid.Row="0" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" HorizontalAlignment="Right"/>
          </Grid>
        </Border>

        <Button x:Name="BtnResetFastFlags" Content="Reset everything to defaults" Classes="ghost" HorizontalAlignment="Left"/>
      </StackPanel>

      <!-- Global Settings page -->
      <ScrollViewer x:Name="GlobalSettingsPage" IsVisible="False">
        <StackPanel Spacing="14" Margin="0,0,12,0">
          <StackPanel>
            <TextBlock Text="Global Settings" Classes="h1"/>
            <TextBlock Text="Set in-game settings from the KSC-Sharp menu." Classes="subtle"/>
          </StackPanel>

          <TextBlock Text="Presets" Classes="h2" Margin="0,6,0,0"/>
          <TextBlock Text="Rendering and Graphics" Classes="h2" Margin="12,0,0,0" FontSize="13.5"/>

          <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" Margin="2">

              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Current Graphics API" Classes="h2"/>
                  <TextBlock Text="EXPERIMENTAL" Classes="badge"/>
                </StackPanel>
                <TextBlock Text="Switch between Direct3D, OpenGL, and Vulkan. Direct3D is the Windows default." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <ComboBox x:Name="ComboGraphicsApi" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="160">
                <ComboBoxItem Content="Direct3D"/>
                <ComboBoxItem Content="OpenGL"/>
                <ComboBoxItem Content="Vulkan"/>
              </ComboBox>

              <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,12"/>

              <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Framerate Limit" Classes="h2"/>
                <TextBlock Text="Unlock the framerate limit for Korone. Going above 240 FPS is not recommended." Classes="subtle" TextWrapping="Wrap"/>
              </StackPanel>
              <NumericUpDown x:Name="NumFramerateLimit" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                              Width="140" Minimum="1" Maximum="2000" Increment="1" FormatString="0"/>
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Log page -->
      <Grid x:Name="LogPage" RowDefinitions="Auto,*,Auto" IsVisible="False">
        <TextBlock Text="Log" Classes="h1" Margin="0,0,0,14"/>
        <Border Grid.Row="1" Classes="card" Padding="0">
          <TextBox x:Name="LogTextBox"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   Background="Transparent"
                   BorderThickness="0"
                   FontFamily="Consolas,Menlo,monospace"
                   FontSize="12.5"
                   Padding="14"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="6">
          <Button x:Name="BtnClearLog" Content="Clear log" Classes="ghost"/>
          <Button x:Name="BtnCopyLog" Content="Copy log" Classes="ghost"/>
        </StackPanel>
      </Grid>

      <!-- About page -->
      <ScrollViewer x:Name="AboutPage" IsVisible="False">
        <StackPanel Spacing="16" Margin="0,0,12,0">
          <TextBlock Text="About" Classes="h1"/>

          <Border Classes="card">
            <StackPanel Orientation="Horizontal" Spacing="16">
              <Image Source="avares://KSC-Sharp.App/Assets/icon.png" Width="56" Height="56"/>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="KSC-Sharp" Classes="h2"/>
                <TextBlock x:Name="AboutVersionText" Classes="subtle"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Text="Project" Classes="h2"/>
              <TextBlock Text="A cross-platform bootstrapper for Korone (Pekora), styled after Bloxstrap and rewritten from koroneStrap in C#."
                         Classes="subtle" TextWrapping="Wrap"/>
              <WrapPanel>
                <Button x:Name="BtnOpenSource" Classes="secondary" Margin="0,0,8,8" Click="OpenSource_Click">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Viewbox Width="14" Height="14">
                      <Path Fill="{DynamicResource AccentBrush}"
                            Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                    </Viewbox>
                    <TextBlock Text="Source Code" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnOpenIssues" Classes="secondary" Margin="0,0,8,8" Click="OpenIssues_Click">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Viewbox Width="14" Height="14">
                      <Path Fill="{DynamicResource AccentBrush}"
                            Data="M8.893 1.5c-.183-.31-.52-.5-.887-.5s-.703.19-.886.5L.138 13.499a.98.98 0 000 1.001c.193.31.53.501.886.501h13.964c.367 0 .704-.19.877-.5a1.03 1.03 0 00.01-1.002L8.893 1.5zm.133 11.497H6.987v-2.003h2.039v2.003zm0-3.004H6.987V5.987h2.039v4.006z"/>
                    </Viewbox>
                    <TextBlock Text="Report an Issue" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </WrapPanel>
              <TextBlock Text="KSC-Sharp is licensed under GPL-3.0." Classes="subtle" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Text="Credits" Classes="h2"/>

              <StackPanel Spacing="2">
                <Button Content="koroneStrap  →" Classes="ghost" HorizontalContentAlignment="Left" Click="OpenKoroneStrap_Click"/>
                <TextBlock Text="by LittleBigDevs · GPL-3.0 · the Python bootstrapper this is a rewrite of." Classes="subtle" Margin="12,0,0,0" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Spacing="2">
                <Button Content="Bloxstrap  →" Classes="ghost" HorizontalContentAlignment="Left" Click="OpenBloxstrap_Click"/>
                <TextBlock Text="by pizzaboxer / Bloxstrap Labs · MIT · UI/UX reference and the model for features like Discord Rich Presence." Classes="subtle" Margin="12,0,0,0" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Spacing="2">
                <Button Content="Korone Bootstrapper  →" Classes="ghost" HorizontalContentAlignment="Left" Click="OpenKoroneBootstrapper_Click"/>
                <TextBlock Text="by Korone · license not published upstream · the original native bootstrapper this whole lineage descends from." Classes="subtle" Margin="12,0,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Data" Classes="h2"/>
                <TextBlock Text="ⓘ" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="This folder holds the downloaded bootstrapper, your local FastFlags cache, and app settings – never your Pekora client install itself."/>
              </StackPanel>
              <TextBlock Text="Downloaded files and FastFlags live outside the install folder, so an uninstall never leaves game data behind unexpectedly." Classes="subtle" TextWrapping="Wrap"/>
              <Button x:Name="BtnOpenAppData" Content="Open App Data Folder" Classes="secondary" HorizontalAlignment="Left"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</Window>
