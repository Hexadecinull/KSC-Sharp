<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KSCSharp.App.Views.MainWindow"
        Title="KSC-Sharp"
        Width="820" Height="600"
        MinWidth="640" MinHeight="480">
  <Grid RowDefinitions="Auto,Auto,*" Margin="12">

    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="KSC-Sharp" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
      <TextBlock x:Name="SubtitleText" VerticalAlignment="Center" Opacity="0.7"/>
    </StackPanel>

    <StackPanel Grid.Row="1" Spacing="10">

      <Border Padding="10" CornerRadius="6" Background="#12000000">
        <StackPanel Spacing="8">
          <TextBlock Text="Launch" FontWeight="SemiBold"/>
          <WrapPanel x:Name="VersionButtonsPanel"/>
        </StackPanel>
      </Border>

      <Border Padding="10" CornerRadius="6" Background="#12000000">
        <StackPanel Spacing="8">
          <TextBlock Text="Bootstrapper" FontWeight="SemiBold"/>
          <WrapPanel>
            <Button x:Name="BtnFastFlags" Content="FastFlags…" Margin="0,0,8,0"/>
            <Button x:Name="BtnDownloadBootstrapper" Content="Download / Update Bootstrapper" Margin="0,0,8,0"/>
            <Button x:Name="BtnLaunchBootstrapper" Content="Run Bootstrapper" Margin="0,0,8,0"/>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" Height="16" Width="280"/>
            <TextBlock x:Name="ProgressText" Text="0%" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border x:Name="WindowsIntegrationPanel" Padding="10" CornerRadius="6" Background="#12000000">
        <StackPanel Spacing="8">
          <TextBlock Text="Windows Integration" FontWeight="SemiBold"/>
          <WrapPanel>
            <Button x:Name="BtnRegisterUri" Content="Register URI Scheme" Margin="0,0,8,0"/>
            <Button x:Name="BtnUnregisterUri" Content="Unregister URI Scheme" Margin="0,0,8,0"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border x:Name="LinuxIntegrationPanel" Padding="10" CornerRadius="6" Background="#12000000">
        <StackPanel Spacing="8">
          <TextBlock Text="Linux Integration" FontWeight="SemiBold"/>
          <TextBlock Text="Experimental — client versions run under Wine." Opacity="0.7" FontSize="12"/>
          <WrapPanel>
            <Button x:Name="BtnSetupLinuxIntegration" Content="Setup Desktop Integration" Margin="0,0,8,0"/>
            <Button x:Name="BtnRemoveLinuxIntegration" Content="Remove Desktop Integration" Margin="0,0,8,0"/>
          </WrapPanel>
        </StackPanel>
      </Border>

    </StackPanel>

    <Grid Grid.Row="2" Margin="0,12,0,0" RowDefinitions="Auto,*,Auto">
      <TextBlock Text="Log" FontWeight="SemiBold" Margin="0,0,0,6"/>
      <TextBox x:Name="LogTextBox"
               Grid.Row="1"
               AcceptsReturn="True"
               IsReadOnly="True"
               TextWrapping="Wrap"
               FontFamily="Consolas,Menlo,monospace"
               VerticalScrollBarVisibility="Auto"/>
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
        <Button x:Name="BtnClearLog" Content="Clear log"/>
        <Button x:Name="BtnCopyLog" Content="Copy log"/>
      </StackPanel>
    </Grid>

  </Grid>
</Window>
